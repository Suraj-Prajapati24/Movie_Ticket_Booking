# Copy this file to `.env` and fill in your local Postgres credentials.
# (`.env` is gitignored; this example is safe to commit.)

# ─── PostgreSQL ─────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=moviebooking

# ─── Auth ───────────────────────────────────────────────────
# Falls back to a dev secret if unset, but ALWAYS set a strong random
# value in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace_with_a_long_random_string
